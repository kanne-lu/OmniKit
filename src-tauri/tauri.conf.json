{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OmniKit",
  "version": "0.1.3",
  "identifier": "com.kanne-lu.omnikit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OmniKit",
        "width": 1440,
        "height": 960,
        "minWidth": 960,
        "minHeight": 680,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$TEMP/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFCNkVENEFBNjI2MjMxOEUKUldTT01XSmlxdFJ1RzJwR2N6REdxWjMwVTk3NzhlR2JHNkhvNENPTlJhSkZ2Y1RqRGtwVGtXUTgK",
      "endpoints": [
        "https://github.com/kanne-lu/OmniKit/releases/latest/download/latest.json"
      ]
    }
  }
}
